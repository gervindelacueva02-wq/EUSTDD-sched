# Example environment variables (replace values before deploying)
# Do NOT commit real secrets — these are placeholders to commit to the repo.
DATABASE_URL="postgresql://neondb_owner:REPLACE_PASSWORD@ep-your-host-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Use the same string but replace `-pooler` with `-direct` for migrations
DIRECT_DATABASE_URL="postgresql://neondb_owner:REPLACE_PASSWORD@ep-your-host-direct.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Other recommended vars
NODE_ENV=production
NODE_VERSION=20

# Usage notes:
# - Copy this file to .env locally and fill real secrets.
# - Keep .env in .gitignore and set secrets in Render dashboard.