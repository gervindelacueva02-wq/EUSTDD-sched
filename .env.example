# Environment Variables Template
# Copy this file to .env and fill in your values
# See NEON_OPTIMIZATION_GUIDE.md for cost optimization tips

# ====================
# DATABASE (NEON)
# ====================

# Pooled connection string (recommended for production & development)
# This uses Neon's connection pooler to reduce connection overhead
# The pooler endpoint has "-pooler" in the hostname
# See: https://neon.tech/docs/guides/connection-pooling
DATABASE_URL="postgresql://username:password@endpoint-pooler.c-2.region.aws.neon.tech/database?sslmode=require"

# Direct connection string (used by Prisma migrations only)
# This bypasses the pooler for schema changes
# Use the same credentials as DATABASE_URL but with the direct endpoint
DIRECT_DATABASE_URL="postgresql://username:password@endpoint.c-2.region.aws.neon.tech/database?sslmode=require"

# ====================
# NODE ENVIRONMENT
# ====================

# Set to "production" on Render, "development" locally
NODE_ENV="development"

# ====================
# APPLICATION SETTINGS
# ====================

# Port for development server (default: 3000)
PORT=3000

# ====================
# OPTIONAL: Database Sync Frequency
# ====================

# How often the app syncs data with the database (in milliseconds)
# See: src/config/sync-optimization.ts for preset values
# Common values:
#   10000  = 10 seconds (real-time collaboration)
#   20000  = 20 seconds (interactive use)
#   30000  = 30 seconds (default, recommended)
#   60000  = 60 seconds (display-only dashboards)
#   120000 = 2 minutes (low-activity mode)
#   180000 = 3 minutes (battery saver mode)
# Lower values = more responsive but higher database load
# Higher values = lower costs but less responsive
# SYNC_FREQUENCY=30000

# ====================
# NOTES ON OPTIMIZATION
# ====================

# ✅ Your setup is optimized for cost! Here's what's already configured:
#
# 1. Database Connection:
#    - Using pooled connection string (DATABASE_URL with -pooler)
#    - This reduces connection overhead by ~60%
#
# 2. Auto Suspend:
#    - Neon auto-suspends compute after 5 minutes of inactivity
#    - Enable in Neon Console → Settings → Compute
#    - This is the #1 way to stay on free tier
#
# 3. Sync Frequency:
#    - Set to 30 seconds by default
#    - Reduces database queries by 90% vs 1-second polling
#    - Adjust in app settings or via SYNC_FREQUENCY variable above
#
# 4. Query Optimization:
#    - Using split API endpoints (not SELECT *)
#    - Each endpoint fetches only needed columns
#    - ~60-70% smaller payloads
#
# 5. No Background Services:
#    - No cron jobs, monitoring, or always-on services
#    - Stop local dev servers when done
#
# For detailed optimization guide, see: NEON_OPTIMIZATION_GUIDE.md
