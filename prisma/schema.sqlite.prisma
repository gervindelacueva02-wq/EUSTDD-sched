// SQLite schema for LOCAL DEVELOPMENT only
// Copy this to schema.prisma for local development

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = "file:./db/custom.db"
}

// Main schedule data storage - single record for all data
model ScheduleData {
  id             String   @id @default("main")
  events         String   @default("[]")      // JSON string of events
  personnel      String   @default("[]")      // JSON string of personnel statuses
  projects       String   @default("[]")      // JSON string of projects
  tickerMessages String   @default("[]")      // JSON string of ticker messages
  settings       String   @default("{}")      // JSON string of settings
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
